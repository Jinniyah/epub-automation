# Copy this file to .env and fill in your values for CLI/advanced use.
# The GUI never reads this file -- it stores everything in
# %APPDATA%\EpubAutomation\settings.json instead, so both front doors
# don't need separate config paths kept in sync
# (docs/requirements/05-data-settings-and-logging.md).
# Never commit .env to version control.

# --- AI Provider (rename stage, Epic 3) ---
# Supported: gemini | openai | none. Neither gemini nor openai is more
# "default" than the other at this level -- see
# docs/requirements/08-open-questions-and-assumptions.md.
AI_PROVIDER=none
GEMINI_API_KEY=
OPENAI_API_KEY=

# --- Library ---
BOOKS_FOLDER=C:\Users\you\Books

# --- Safety (ported from epub-renamer's existing .env-driven config --
# see docs/design/SYSTEM_DESIGN.md §7.6) ---
DRY_RUN=true
MAX_FILES=50

# --- Audio stage (Epic 4) ---
# Reserved, not yet implemented -- see docs/requirements/01-architecture.md
# §CLI: reserved --workers flag and ADR-0009. The GUI always stays serial
# (1); this flag exists so the CLI/advanced front door isn't
# architecturally blocked from adding real parallelism later.
WORKERS=1

# --- Debugging ---
DEBUG_AI=false
